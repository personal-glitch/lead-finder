# ─────────────────────────────────────────────────────────────────────────────
# Lead-Finder – Umgebungsvariablen
#
# Die App läuft OHNE jegliche Keys (lokaler Datei-Store, keine E-Mail).
# Sobald die Supabase- bzw. Resend-Variablen gesetzt sind, schalten sich
# Persistenz/Auth bzw. E-Mail-Versand automatisch frei (Feature-Flags).
# Kopiere diese Datei nach `.env.local` und trage deine Werte ein.
# ─────────────────────────────────────────────────────────────────────────────

# Öffentliche Basis-URL der App (für Abmelde-Links in E-Mails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OpenStreetMap (Pflicht-Etikette) ────────────────────────────────────────
# Nominatim & Overpass verlangen einen aussagekräftigen User-Agent mit Kontakt.
# Bitte mit eigener Domain/Mail ersetzen, sonst droht eine Sperre.
OSM_USER_AGENT=LeadFinder/1.0 (kontakt@deinedomain.de)
# Optional überschreibbar (z. B. eigener Mirror). Nominatim → Fallback Photon;
# Overpass mit Fallback-Mirror. Ist Overpass gar nicht erreichbar (z. B. IP-Sperre
# in Cloud/Sandbox), zeigt die Suche klar markierte BEISPIEL-Treffer statt eines Fehlers.
# NOMINATIM_URL=https://nominatim.openstreetmap.org/search
# PHOTON_URL=https://photon.komoot.io/api/
# OVERPASS_URL=https://overpass-api.de/api/interpreter

# ── Supabase (optional – aktiviert Persistenz + ANMELDUNG) ──────────────────
# Sind diese Werte gesetzt, gilt: Login-Pflicht (E-Mail + Passwort), jede
# Firma sieht nur ihre eigenen Daten (owner_id = auth.uid()). Ohne die Werte
# läuft die App im lokalen Demo-Modus ganz ohne Anmeldung.
#
# Einrichtung (einmalig):
#  1) Projekt auf supabase.com anlegen → Project Settings → API kopieren.
#  2) Migrationen einspielen: SQL aus supabase/migrations/ im SQL-Editor
#     ausführen (oder `supabase db push`).
#  3) Authentication → URL Configuration: Site URL = NEXT_PUBLIC_APP_URL,
#     Redirect URL = <APP_URL>/auth/callback eintragen.
#  4) Werte unten setzen und Server neu starten.
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Nur server-seitig, niemals an den Client geben:
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (optional – Plattform-Fallback für E-Mail) ───────────────────────
# Hinweis: Nutzer hinterlegen ihren EIGENEN SMTP-Zugang in den Einstellungen.
# Resend ist nur der optionale Fallback, wenn kein eigener Absender gesetzt ist.
# RESEND_API_KEY=re_...
# RESEND_FROM="Deine Firma <vertrieb@deinedomain.de>"
# Pflicht-Footer (Impressum) für jede ausgehende Werbe-E-Mail (rechtlich nötig):
# SENDER_IMPRESSUM="Deine Firma GmbH · Musterstr. 1 · 50667 Köln · GF: Max Muster · HRB 12345 Amtsgericht Köln"

# ── Sicherheit: Schlüssel zum Verschlüsseln gespeicherter Secrets (SMTP-Passwort)
# Stabil halten! Ohne diesen Wert wird der Supabase-Service-Key als Schlüssel genutzt.
# APP_SECRET=ein-langes-zufaelliges-geheimnis

# ── Stripe (optional – aktiviert die 49-€-Abrechnung) ───────────────────────
# 1) Produkt+Preis (49 €/Monat, wiederkehrend) in Stripe anlegen → Price-ID kopieren.
# 2) Webhook auf <APP_URL>/api/billing/webhook einrichten (Events: checkout.session.completed,
#    customer.subscription.updated, customer.subscription.deleted) → Signing-Secret kopieren.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Superadmin: nur diese E-Mail sieht /admin (Übersicht testend/angemeldet/zahlend)
# SUPER_ADMIN_EMAIL=du@deinefirma.de
